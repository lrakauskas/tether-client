{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "tether/client",
    "description": "Laravel client integration layer for the Tether offline-first sync system.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0|^13.0",
        "tether/core": "^0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "orchestra/testbench": "^10.0",
        "larastan/larastan": "^3.9",
        "symplify/easy-coding-standard": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "Tether\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tether\\Client\\TetherClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": [
            "@php vendor/bin/pest"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse"
        ],
        "ecs": [
            "@php vendor/bin/ecs --fix"
        ]
    }
}
